{
  "manifest_version": 3,
  "name": "BareTube",
  "version": "1.0",
  "description": "Removes distractions from YouTube so you can focus on videos and comments.",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "baretube@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["scripting", "activeTab", "storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
